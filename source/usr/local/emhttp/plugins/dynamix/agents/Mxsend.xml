<Agent>
  <Name>Mxsend</Name>
  <Variables>
    <Variable Help="Sender's full Matrix user ID, e.g. @bot:matrix.server.org" Desc="Sender (From)" Default="">FROM</Variable>
    <Variable Help="Password for the Matrix account. Avoid characters that Unraid treats as INI comments: # and ; — they will break config display." Desc="Password" Default="">PASSWORD</Variable>
    <Variable Help="Recipient — a room ID (!room:server) or user ID (@user:server)" Desc="Recipient (To)" Default="">TO</Variable>
    <Variable Help="Recovery key for E2EE device verification (set to 'none' to disable)" Desc="Recovery Key" Default="none">RECOVERY_KEY</Variable>
    <Variable Help="Fields included in the notification title" Desc="Notification Title" Default="$SUBJECT">TITLE</Variable>
    <Variable Help="Fields included in the notification message body" Desc="Notification Message" Default="$DESCRIPTION">MESSAGE</Variable>
  </Variables>
  <Script>
    <![CDATA[
#!/bin/bash
    ############
    {0}
    ############
    TITLE=$(printf '%b' "$TITLE")
    MESSAGE=$(printf '%b' "$MESSAGE")
    RECOVERY_ARGS=()
    [ "$RECOVERY_KEY" != "none" ] && RECOVERY_ARGS=(--recovery-key "$RECOVERY_KEY")
    /usr/local/bin/mxsend \
      --from "$FROM" --password "$PASSWORD" --to "$TO" \
      "${RECOVERY_ARGS[@]}" \
      "$(printf '%s: %s\n\n%s' "$(hostname)" "$TITLE" "$MESSAGE")"
    ]]>
  </Script>
</Agent>
